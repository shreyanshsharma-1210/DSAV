# Copy this file to `.env.local` and fill in your key.
# `.env.local` is gitignored (matched by `*.local`).
#
# WARNING: Vite exposes any variable prefixed with VITE_ to the browser bundle.
# That means your Groq key will be visible to anyone who opens devtools on the deployed site.
# For a personal demo this is acceptable; for production, proxy the request through a server
# function / Cloudflare Worker route and read the key from a non-VITE_ variable.

VITE_GROQ_API_KEY=
# Optional: override the model. Defaults to llama-3.1-8b-instant.
VITE_GROQ_MODEL=llama-3.1-8b-instant
